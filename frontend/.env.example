# ローカル開発: 未設定でよい（相対 /api → Vite が 127.0.0.1:8000 にプロキシ）
# 本番（Vercel 等）: 必ず絶対 URL（例: https://api.example.com/api）
# NUXT_PUBLIC_API_BASE_URL=https://your-api.example.com/api

# Laravel Reverb / Echo（リアルタイム同期）
# backend/.env の REVERB_APP_KEY / REVERB_HOST / REVERB_PORT / REVERB_SCHEME と一致させる
NUXT_PUBLIC_REVERB_KEY=local-key
NUXT_PUBLIC_REVERB_HOST=127.0.0.1
NUXT_PUBLIC_REVERB_PORT=8080
NUXT_PUBLIC_REVERB_SCHEME=http
